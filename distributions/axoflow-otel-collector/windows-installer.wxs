<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
   <Product
      Name="Axoflow OpenTelemetry Collector"
      Id="CC9915C6-DF03-4F84-ACCB-6EB9492C9F3F"
      UpgradeCode="BBD75D8E-8F77-440A-B780-4F30C3E099B6"
      Version="{{ .Version }}"
      Manufacturer="Axoflow Inc."
      Language="1033">
      
      <Package
         InstallerVersion="200"
         Compressed="yes"
         Comments="Windows Installer Package"
         InstallScope="perMachine"/>
      <Media Id="1" Cabinet="product.cab" EmbedCab="yes"/>
      <Icon Id="ProductIcon" SourceFile="axoflow.ico"/>
      <Property Id="ARPPRODUCTICON" Value="ProductIcon"/>
      <Property Id="ARPHELPLINK" Value="https://axoflow.com/"/>
      <Property Id="ARPURLINFOABOUT" Value="https://axoflow.com/"/>
      <Property Id="ARPNOREPAIR" Value="1"/>
      <Property Id="ARPNOMODIFY" Value="1"/>

      <MajorUpgrade
         DowngradeErrorMessage="A later version of Axoflow OpenTelemetry Collector already installed. Setup will now exit."/>

      <Property Id="CONFIG_PATH" Value="[CommonAppDataFolder]Axoflow\OpenTelemetry Collector\config.yaml" />

      <Property Id="CONFIG_FILE_EXISTS">
         <DirectorySearch Id="AppDataFolderSearch" Path="[CommonAppDataFolder]">
            <DirectorySearch Id="AxoflowSearch" Path="Axoflow">
               <DirectorySearch Id="OpenTelemetryCollectorSearch" Path="OpenTelemetry Collector">
                  <FileSearch Id="ConfigSearch" Name="config.yaml" />
               </DirectorySearch>
            </DirectorySearch>
         </DirectorySearch>
      </Property>

      <Property Id="COLLECTOR_SVC_ARGS"/>
      <CustomAction
         Id="SetCollectorSvcArgs"
         Property="COLLECTOR_SVC_ARGS"
         Value="--config &quot;[CONFIG_PATH]&quot;"/>

      <CustomAction 
         Id="CreateConfigDir" 
         ExeCommand="cmd /c if not exist &quot;[CommonAppDataFolder]Axoflow\OpenTelemetry Collector&quot; mkdir &quot;[CommonAppDataFolder]Axoflow\OpenTelemetry Collector&quot;" 
         Directory="INSTALLDIR" 
         Impersonate="no" 
         Execute="deferred" 
         Return="check" />

      <CustomAction 
         Id="CopyConfig" 
         ExeCommand="cmd /c if not exist &quot;[CONFIG_PATH]&quot; copy /y &quot;[INSTALLDIR]config.yaml&quot; &quot;[CONFIG_PATH]&quot;" 
         Directory="INSTALLDIR" 
         Impersonate="no" 
         Execute="deferred" 
         Return="check" />

      <InstallExecuteSequence>
         <Custom Action="SetCollectorSvcArgs" Before="InstallFiles">NOT COLLECTOR_SVC_ARGS</Custom>
         <Custom Action="CreateConfigDir" After="InstallFiles">NOT Installed</Custom>
         <Custom Action="CopyConfig" After="CreateConfigDir">NOT CONFIG_FILE_EXISTS AND NOT Installed</Custom>
      </InstallExecuteSequence>

      <Feature Id="Feature" Level="1">
         <ComponentRef Id="ApplicationComponent"/>
         <ComponentRef Id="ConfigDirectoryComponent"/>
      </Feature>

      <Directory Id="TARGETDIR" Name="SourceDir">
         <Directory Id="ProgramFiles64Folder">
            <Directory Id="COMPANYDIR" Name="Axoflow">
               <Directory Id="INSTALLDIR" Name="OpenTelemetry Collector">
                  <Component Id="ApplicationComponent" Guid="A4EC99AE-4DBA-4C66-81C5-6434236CC031">
                     <!-- Files to include -->
                     <File
                        Id="{{ .Binary }}.exe"
                        Name="{{ .Binary }}.exe"
                        Source="{{ .Binary }}.exe"
                        KeyPath="yes"/>
                     <File
                        Id="config.yaml"
                        Name="config.yaml"
                        Source="windows_config.yaml"
                        NeverOverwrite="yes"/>
                     <File
                        Id="README.md"
                        Name="README.md"
                        Source="README_windows.md"/>

                     <ServiceInstall
                        Id="Sevice"
                        Name="{{ .Binary }}"
                        DisplayName="Axoflow OpenTelemetry Collector"
                        Description="Collects, processes, and exports telemetry from various configurable sources."
                        Type="ownProcess"
                        Vital="yes"
                        Start="auto"
                        Account="LocalSystem"
                        ErrorControl="normal"
                        Arguments="[COLLECTOR_SVC_ARGS]"
                        Interactive="no"/>
                     <ServiceControl
                        Id="StartStopRemoveService"
                        Name="{{ .Binary }}"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes"/>

                     <RegistryKey
                        Root="HKLM"
                        Key="SYSTEM\CurrentControlSet\Services\EventLog\Application\{{ .Binary }}">
                        <RegistryValue 
                           Type="expandable"
                           Name="EventMessageFile"
                           Value="%SystemRoot%\System32\EventCreate.exe"/>
                     </RegistryKey>
                  </Component>
               </Directory>
            </Directory>
         </Directory>
         
         <Directory Id="CommonAppDataFolder">
            <Directory Id="AxoflowDataDir" Name="Axoflow">
               <Directory Id="CollectorDataDir" Name="OpenTelemetry Collector">
                  <Component Id="ConfigDirectoryComponent" Guid="B5EC99AE-4DBA-4C66-81C5-6434236CC032">
                     <CreateFolder>
                        <Permission User="Everyone" GenericAll="yes"/>
                     </CreateFolder>
                  </Component>
               </Directory>
            </Directory>
         </Directory>
      </Directory>
   </Product>
</Wix>
